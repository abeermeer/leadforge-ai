# --- Core ---
SECRET_KEY=change-me-jwt-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key
APP_BASE_URL=http://localhost:8000

# --- Infra ---
DATABASE_URL=postgresql://trax9:password@localhost:5432/trax9_leads
REDIS_URL=redis://localhost:6379/0
DB_PASSWORD=password

# --- Scraping ---
# Comma-separated proxy URLs, or a single rotating-proxy endpoint. Empty = direct.
PROXY_POOL=

# --- Sending defaults (per-user overrides live in user_settings) ---
DEFAULT_MAX_EMAILS_PER_DAY=100
DEFAULT_MAX_EMAILS_PER_HOUR=50
SEND_START_HOUR=8
SEND_END_HOUR=18

# --- Enrichment ---
SOCIAL_ENRICH_MIN_SCORE=60

# --- Observability (optional) ---
SENTRY_DSN=
