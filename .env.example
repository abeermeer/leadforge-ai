# --- Core ---
SECRET_KEY=change-me-jwt-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key
APP_BASE_URL=http://localhost:8000

# --- Infra ---
DATABASE_URL=postgresql://trax9:password@localhost:5432/trax9_leads
REDIS_URL=redis://localhost:6379/0
DB_PASSWORD=password
REDIS_PASSWORD=change-me-redis-password
# DEBUG=false in production. With DEBUG=false the app refuses to boot unless
# SECRET_KEY and FERNET_KEY are set to real (non-placeholder) values.
DEBUG=true

# --- Security ---
# Comma-separated browser origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# SendGrid Event Webhook verification key (Settings > Mail Settings > Signed Event Webhook).
# When set, incoming event webhooks must carry a valid signature.
SENDGRID_WEBHOOK_VERIFICATION_KEY=
# Secret embedded in the inbound-parse URL: /api/webhook/inbound/<this-value>
INBOUND_WEBHOOK_SECRET=

# --- Scraping ---
# Comma-separated proxy URLs, or a single rotating-proxy endpoint. Empty = direct.
PROXY_POOL=

# --- Sending defaults (per-user overrides live in user_settings) ---
DEFAULT_MAX_EMAILS_PER_DAY=100
DEFAULT_MAX_EMAILS_PER_HOUR=50
SEND_START_HOUR=8
SEND_END_HOUR=18

# --- Enrichment ---
SOCIAL_ENRICH_MIN_SCORE=60

# --- Observability (optional) ---
SENTRY_DSN=
